{
  "manifest_version": 3,
  "name": "GazeIQ",
  "version": "1.0",
  "description": "Auto-pause video streaming platforms when you are not looking.",
  "permissions": ["offscreen", "storage", "tabs", "scripting", "idle"],
  "host_permissions": [
    "*://*.youtube.com/*",
    "*://*.netflix.com/*",
    "*://*.primevideo.com/*",
    "*://*.amazon.com/*",
    "*://*.amazon.in/*",
    "*://*.amazon.co.uk/*",
    "*://*.hotstar.com/*"
  ],
  "background": {
    "service_worker": "service_daemon.js"
  },
  "action": {
    "default_popup": "menu.html",
    "default_title": "GazeIQ Settings"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*",
        "*://*.netflix.com/*",
        "*://*.primevideo.com/*",
        "*://*.amazon.com/*",
        "*://*.amazon.in/*",
        "*://*.amazon.co.uk/*",
        "*://*.hotstar.com/*"
      ],
      "js": ["player_controller.js"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
  }
}
